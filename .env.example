# ═══════════════════════════════════════════════════
# HomeVisualizer — Environment Variables
# Copy to .env.local and fill in your values
# ═══════════════════════════════════════════════════

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Admin
ADMIN_PASSWORD=changeme

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Providers (at least one required for live mode; none = demo mode)
OPENAI_API_KEY=sk-...
# BFL_API_KEY=          # Optional: Flux Kontext Max fallback
# STABILITY_API_KEY=    # Optional: Stability SDXL fallback
# AI_PROVIDER=openai    # Default provider: openai|flux|stability

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Monthly subscriptions
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...
# One-time licenses
STRIPE_PRICE_LICENSE_STARTER=price_...
STRIPE_PRICE_LICENSE_PRO=price_...
STRIPE_PRICE_LICENSE_AGENCY=price_...

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com
