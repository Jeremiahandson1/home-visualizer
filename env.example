# ═══════════════════════════════════════════════════
# HomeVisualizer — Environment Variables
# Copy to .env.local and fill in your values
# ═══════════════════════════════════════════════════

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Admin
ADMIN_PASSWORD=changeme
# ADMIN_TOKEN_SECRET=   # Optional: separate HMAC secret. Defaults to ADMIN_PASSWORD if not set.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Providers (at least one required for live mode; none = demo mode)
OPENAI_API_KEY=sk-...
# BFL_API_KEY=          # Optional: Flux Kontext Max fallback
# STABILITY_API_KEY=    # Optional: Stability SDXL fallback
# AI_PROVIDER=openai    # Default provider: openai|flux|stability

# Stripe Billing — 2 plans: monthly subscription + one-time license
# Run `node scripts/seed-stripe.js` to create products and get these IDs.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...       # $49/mo subscription (200 renders)
STRIPE_PRICE_LICENSE=price_...       # $1,497 one-time license (unlimited)

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com
